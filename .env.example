# Railway injects PORT automatically.
PORT=3000

# Add a Railway PostgreSQL service, then reference its internal URL.
DATABASE_URL=postgresql://user:password@host:5432/database

# Set this after Railway generates the public domain.
NEXT_PUBLIC_SITE_URL=https://your-domain.example

# Keep this secret in Railway Variables. Never expose it in browser code.
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-5.5
OPENAI_VOICE_MODEL=gpt-4o-mini-tts
OPENAI_VOICE=marin
